    "check:phase76-requirements-save-field-coverage": "node scripts/check-phase76-requirements-save-field-coverage.cjs && npm run check:phase77-requirements-runtime-persistence",
    "check:phase77-requirements-runtime-persistence": "node scripts/check-phase77-requirements-runtime-persistence.cjs && npm run check:phase78-requirements-runtime-truth-bomb",
    "check:phase78-requirements-runtime-truth-bomb": "node scripts/check-phase78-requirements-runtime-truth-bomb.cjs && npm run check:phase79-requirements-read-repair-materialization",
    "check:phase79-requirements-read-repair-materialization": "node scripts/check-phase79-requirements-read-repair-materialization.cjs && npm run check:phase80-validation-diagram-reconciliation",
