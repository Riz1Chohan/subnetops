    "check:phase61-requirements-materialization": "node scripts/check-phase61-requirements-materialization.cjs && npm run check:phase62-requirements-impact-traceability",
    "check:phase62-requirements-impact-traceability": "node scripts/check-phase62-requirements-impact-traceability.cjs && npm run check:phase63-requirements-policy-consequences",
    "check:phase63-requirements-policy-consequences": "node scripts/check-phase63-requirements-policy-consequences.cjs && npm run check:phase64-requirements-completion-closure",
