generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  passwordHash  String
  fullName      String?
  planTier      PlanTier        @default(FREE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  projects      Project[]
  memberships   Membership[]
  comments      ProjectComment[]
  assignedComments ProjectComment[] @relation("AssignedCommentUser")
  notifications Notification[]
  notificationPreference NotificationPreference?
  watches       ProjectWatch[]
  passwordResetTokens PasswordResetToken[]
}

enum NotificationType {
  INVITE
  MENTION
  COMMENT
  REVIEW
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Notification {
  id          String             @id @default(uuid())
  userId      String
  type        NotificationType   @default(SYSTEM)
  title       String
  message     String
  link        String?
  status      NotificationStatus @default(UNREAD)
  createdAt   DateTime           @default(now())
  readAt      DateTime?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailOutbox {
  id          String   @id @default(uuid())
  toEmail     String
  subject     String
  templateKey String
  payloadJson String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model Project {
  id               String             @id @default(uuid())
  userId           String
  organizationId   String?
  name             String
  description      String?
  organizationName String?
  environmentType  String?
  basePrivateRange String?
  logoUrl          String?
  reportHeader     String?
  reportFooter     String?
  approvalStatus   ApprovalStatus     @default(DRAFT)
  reviewerNotes    String?
  requirementsJson String?
  discoveryJson    String?
  platformProfileJson String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  sites            Site[]
  validations      ValidationResult[]
  exports          ExportLog[]
  changeLogs       ChangeLog[]
  comments         ProjectComment[]
  watches          ProjectWatch[]
}

model Site {
  id                  String   @id @default(uuid())
  projectId           String
  name                String
  location            String?
  streetAddress       String?
  buildingLabel       String?
  floorLabel          String?
  siteCode            String?
  notes               String?
  defaultAddressBlock String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vlans               Vlan[]

  @@index([projectId])
}

model Vlan {
  id             String   @id @default(uuid())
  siteId         String
  vlanId         Int
  vlanName       String
  purpose        String?
  subnetCidr     String
  gatewayIp      String
  dhcpEnabled    Boolean  @default(true)
  estimatedHosts Int?
  department     String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([vlanId])
  @@unique([siteId, vlanId])
}

model ValidationResult {
  id         String             @id @default(uuid())
  projectId  String
  severity   ValidationSeverity
  ruleCode   String
  title      String
  message    String
  entityType EntityType
  entityId   String?
  createdAt  DateTime           @default(now())
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ExportLog {
  id         String     @id @default(uuid())
  projectId  String
  exportType ExportType
  createdAt  DateTime   @default(now())
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum PlanTier {
  FREE
  PAID
}

enum ValidationSeverity {
  ERROR
  WARNING
  INFO
}

enum ExportType {
  CSV
  PDF
}

enum EntityType {
  PROJECT
  SITE
  VLAN
}

model ChangeLog {
  id         String   @id @default(uuid())
  projectId  String
  actorLabel String?
  message    String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum ApprovalStatus {
  DRAFT
  IN_REVIEW
  APPROVED
}

model Organization {
  id           String          @id @default(uuid())
  name         String
  slug         String          @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  memberships  Membership[]
  invitations  OrgInvitation[]
  projects     Project[]
}

model Membership {
  id             String        @id @default(uuid())
  userId         String
  organizationId String
  role           OrgRole       @default(MEMBER)
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model ProjectComment {
  id                  String              @id @default(uuid())
  projectId           String
  userId              String
  parentId            String?
  assignedToUserId    String?
  body                String
  isResolved          Boolean             @default(false)
  isPinned            Boolean             @default(false)
  visibility          CommentVisibility   @default(ALL)
  taskStatus          CommentTaskStatus   @default(OPEN)
  priority            CommentTaskPriority @default(MEDIUM)
  dueDate             DateTime?
  reminderLastQueuedAt DateTime?
  targetType          CommentTargetType   @default(PROJECT)
  targetId            String?
  createdAt           DateTime            @default(now())
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo  User?             @relation("AssignedCommentUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  parent     ProjectComment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ProjectComment[]  @relation("CommentReplies")

  @@index([projectId])
  @@index([parentId])
}

enum CommentVisibility {
  ALL
  REVIEWER_ONLY
}

enum CommentTaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum CommentTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CommentTargetType {
  PROJECT
  SITE
  VLAN
  VALIDATION
}

model OrgInvitation {
  id             String   @id @default(uuid())
  organizationId String
  email          String
  role           OrgRole  @default(MEMBER)
  token          String   @unique
  status         InviteStatus @default(PENDING)
  invitedByUserId String
  createdAt      DateTime @default(now())
  acceptedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

model ProjectWatch {
  id         String   @id @default(uuid())
  projectId   String
  userId      String
  createdAt   DateTime @default(now())
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model NotificationPreference {
  userId                String   @id
  inAppInvites          Boolean  @default(true)
  inAppMentions         Boolean  @default(true)
  emailInvites          Boolean  @default(false)
  emailMentions         Boolean  @default(false)
  overdueReminders      Boolean  @default(false)
  emailDigests          Boolean  @default(false)
  digestFrequency       DigestFrequency @default(DAILY)
  lastDigestQueuedAt    DateTime?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DigestFrequency {
  DAILY
  WEEKLY
}
