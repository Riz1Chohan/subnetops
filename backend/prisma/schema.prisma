generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  passwordHash  String
  fullName      String?
  planTier      PlanTier        @default(FREE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  projects      Project[]
  memberships   Membership[]
  comments      ProjectComment[]
  assignedComments ProjectComment[] @relation("AssignedCommentUser")
  notifications Notification[]
  notificationPreference NotificationPreference?
  watches       ProjectWatch[]
  passwordResetTokens PasswordResetToken[]
}

enum NotificationType {
  INVITE
  MENTION
  COMMENT
  REVIEW
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Notification {
  id          String             @id @default(uuid())
  userId      String
  type        NotificationType   @default(SYSTEM)
  title       String
  message     String
  link        String?
  status      NotificationStatus @default(UNREAD)
  createdAt   DateTime           @default(now())
  readAt      DateTime?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailOutbox {
  id          String   @id @default(uuid())
  toEmail     String
  subject     String
  templateKey String
  payloadJson String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model Project {
  id               String             @id @default(uuid())
  userId           String
  organizationId   String?
  name             String
  description      String?
  organizationName String?
  environmentType  String?
  basePrivateRange String?
  logoUrl          String?
  reportHeader     String?
  reportFooter     String?
  approvalStatus   ApprovalStatus     @default(DRAFT)
  reviewerNotes    String?
  requirementsJson String?
  discoveryJson    String?
  platformProfileJson String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  sites            Site[]
  validations      ValidationResult[]
  exports          ExportLog[]
  changeLogs       ChangeLog[]
  comments         ProjectComment[]
  watches          ProjectWatch[]
  routeDomains     DesignRouteDomain[]
  ipPools          DesignIpPool[]
  ipAllocations    DesignIpAllocation[]
  dhcpScopes       DesignDhcpScope[]
  ipReservations   DesignIpReservation[]
  brownfieldImports DesignBrownfieldImport[]
  brownfieldNetworks DesignBrownfieldNetwork[]
  brownfieldConflictResolutions DesignBrownfieldConflictResolution[]
  allocationApprovals DesignAllocationApproval[]
  allocationLedger DesignAllocationLedgerEntry[]
}

model Site {
  id                  String   @id @default(uuid())
  projectId           String
  name                String
  location            String?
  streetAddress       String?
  buildingLabel       String?
  floorLabel          String?
  siteCode            String?
  notes               String?
  defaultAddressBlock String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vlans               Vlan[]
  ipPools             DesignIpPool[]
  ipAllocations       DesignIpAllocation[]
  dhcpScopes          DesignDhcpScope[]
  ipReservations      DesignIpReservation[]

  @@index([projectId])
}

model Vlan {
  id             String   @id @default(uuid())
  siteId         String
  vlanId         Int
  vlanName       String
  purpose        String?
  segmentRole    String?
  subnetCidr     String
  gatewayIp      String
  dhcpEnabled    Boolean  @default(true)
  estimatedHosts Int?
  department     String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  ipAllocations  DesignIpAllocation[]
  dhcpScopes     DesignDhcpScope[]
  ipReservations DesignIpReservation[]

  @@index([siteId])
  @@index([vlanId])
  @@unique([siteId, vlanId])
}

model ValidationResult {
  id         String             @id @default(uuid())
  projectId  String
  severity   ValidationSeverity
  ruleCode   String
  title      String
  message    String
  entityType EntityType
  entityId   String?
  createdAt  DateTime           @default(now())
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ExportLog {
  id         String     @id @default(uuid())
  projectId  String
  exportType ExportType
  createdAt  DateTime   @default(now())
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum PlanTier {
  FREE
  PAID
}

enum ValidationSeverity {
  ERROR
  WARNING
  INFO
}

enum ExportType {
  CSV
  PDF
}

enum EntityType {
  PROJECT
  SITE
  VLAN
}

model ChangeLog {
  id         String   @id @default(uuid())
  projectId  String
  actorLabel String?
  message    String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum ApprovalStatus {
  DRAFT
  IN_REVIEW
  APPROVED
}

model Organization {
  id           String          @id @default(uuid())
  name         String
  slug         String          @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  memberships  Membership[]
  invitations  OrgInvitation[]
  projects     Project[]
}

model Membership {
  id             String        @id @default(uuid())
  userId         String
  organizationId String
  role           OrgRole       @default(MEMBER)
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model ProjectComment {
  id                  String              @id @default(uuid())
  projectId           String
  userId              String
  parentId            String?
  assignedToUserId    String?
  body                String
  isResolved          Boolean             @default(false)
  isPinned            Boolean             @default(false)
  visibility          CommentVisibility   @default(ALL)
  taskStatus          CommentTaskStatus   @default(OPEN)
  priority            CommentTaskPriority @default(MEDIUM)
  dueDate             DateTime?
  reminderLastQueuedAt DateTime?
  targetType          CommentTargetType   @default(PROJECT)
  targetId            String?
  createdAt           DateTime            @default(now())
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo  User?             @relation("AssignedCommentUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  parent     ProjectComment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    ProjectComment[]  @relation("CommentReplies")

  @@index([projectId])
  @@index([parentId])
}

enum CommentVisibility {
  ALL
  REVIEWER_ONLY
}

enum CommentTaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum CommentTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CommentTargetType {
  PROJECT
  SITE
  VLAN
  VALIDATION
}

model OrgInvitation {
  id             String   @id @default(uuid())
  organizationId String
  email          String
  role           OrgRole  @default(MEMBER)
  token          String   @unique
  status         InviteStatus @default(PENDING)
  invitedByUserId String
  createdAt      DateTime @default(now())
  acceptedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

model ProjectWatch {
  id         String   @id @default(uuid())
  projectId   String
  userId      String
  createdAt   DateTime @default(now())
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model NotificationPreference {
  userId                String   @id
  inAppInvites          Boolean  @default(true)
  inAppMentions         Boolean  @default(true)
  emailInvites          Boolean  @default(false)
  emailMentions         Boolean  @default(false)
  overdueReminders      Boolean  @default(false)
  emailDigests          Boolean  @default(false)
  digestFrequency       DigestFrequency @default(DAILY)
  lastDigestQueuedAt    DateTime?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DigestFrequency {
  DAILY
  WEEKLY
}


enum AddressFamily {
  IPV4
  IPV6
}

enum IpPoolScope {
  ORGANIZATION
  SITE
  SEGMENT
  TRANSIT
  LOOPBACK
  RESERVED
}

enum IpPoolStatus {
  ACTIVE
  RESERVED
  DEPRECATED
}

enum IpAllocationStatus {
  PROPOSED
  REVIEW_REQUIRED
  APPROVED
  REJECTED
  SUPERSEDED
  IMPLEMENTED
}

enum BrownfieldImportStatus {
  IMPORTED
  REVIEWED
  SUPERSEDED
}

enum BrownfieldObjectKind {
  NETWORK
  VLAN
  DHCP_SCOPE
  RESERVATION
  ROUTE
  FIREWALL_POLICY
  UNKNOWN
}

enum AllocationApprovalDecision {
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

enum AllocationLedgerAction {
  CREATED
  UPDATED
  APPROVED
  REJECTED
  SUPERSEDED
  IMPLEMENTED
  STALE_DETECTED
  IMPORTED
}

model DesignRouteDomain {
  id                    String   @id @default(uuid())
  projectId             String
  routeDomainKey        String
  name                  String
  vrfName               String?
  routeDistinguisher    String?
  description           String?
  allowOverlappingCidrs Boolean  @default(false)
  sourceState           String   @default("configured")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ipPools               DesignIpPool[]
  ipAllocations         DesignIpAllocation[]
  dhcpScopes            DesignDhcpScope[]

  @@unique([projectId, routeDomainKey])
  @@index([projectId])
}

model DesignIpPool {
  id            String        @id @default(uuid())
  projectId     String
  routeDomainId String?
  siteId        String?
  name          String
  addressFamily AddressFamily
  scope         IpPoolScope    @default(SITE)
  cidr          String
  status        IpPoolStatus   @default(ACTIVE)
  purpose       String?
  ownerLabel    String?
  businessUnit  String?
  reservePercent Int          @default(20)
  noAllocate    Boolean       @default(false)
  sourceState   String        @default("configured")
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  routeDomain   DesignRouteDomain? @relation(fields: [routeDomainId], references: [id], onDelete: SetNull)
  site          Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  allocations   DesignIpAllocation[]

  @@index([projectId])
  @@index([routeDomainId])
  @@index([siteId])
}

model DesignIpAllocation {
  id            String             @id @default(uuid())
  projectId     String
  poolId        String?
  routeDomainId String?
  siteId        String?
  vlanId        String?
  addressFamily AddressFamily
  cidr          String
  gatewayIp     String?
  purpose       String?
  status        IpAllocationStatus @default(PROPOSED)
  source        String             @default("engine2")
  confidence    String             @default("proposed")
  inputHash     String?
  approvedAt    DateTime?
  implementedAt DateTime?
  supersededByAllocationId String?
  supersessionReason String?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pool          DesignIpPool?      @relation(fields: [poolId], references: [id], onDelete: SetNull)
  routeDomain   DesignRouteDomain? @relation(fields: [routeDomainId], references: [id], onDelete: SetNull)
  site          Site?              @relation(fields: [siteId], references: [id], onDelete: SetNull)
  vlan          Vlan?              @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  dhcpScopes    DesignDhcpScope[]
  reservations  DesignIpReservation[]
  approvals     DesignAllocationApproval[]
  ledgerEntries DesignAllocationLedgerEntry[]

  @@index([projectId])
  @@index([poolId])
  @@index([routeDomainId])
  @@index([siteId])
  @@index([vlanId])
}

model DesignDhcpScope {
  id               String        @id @default(uuid())
  projectId        String
  siteId           String?
  vlanId           String?
  routeDomainId    String?
  allocationId     String?
  addressFamily    AddressFamily @default(IPV4)
  scopeCidr        String
  defaultGateway   String?
  dnsServersJson   String?
  leaseSeconds     Int?
  excludedRangesJson String?
  optionsJson      String?
  relayTargetsJson String?
  serverLocation   String?
  source           String        @default("configured")
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  site             Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  vlan             Vlan?         @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  routeDomain      DesignRouteDomain? @relation(fields: [routeDomainId], references: [id], onDelete: SetNull)
  allocation       DesignIpAllocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  reservations     DesignIpReservation[]

  @@index([projectId])
  @@index([siteId])
  @@index([vlanId])
  @@index([routeDomainId])
}

model DesignIpReservation {
  id            String        @id @default(uuid())
  projectId     String
  siteId        String?
  vlanId        String?
  dhcpScopeId   String?
  allocationId  String?
  addressFamily AddressFamily @default(IPV4)
  ipAddress     String
  macAddress    String?
  hostname      String?
  ownerLabel    String?
  purpose       String?
  source        String        @default("configured")
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  site          Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  vlan          Vlan?         @relation(fields: [vlanId], references: [id], onDelete: SetNull)
  dhcpScope     DesignDhcpScope? @relation(fields: [dhcpScopeId], references: [id], onDelete: SetNull)
  allocation    DesignIpAllocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([dhcpScopeId])
  @@index([allocationId])
}

model DesignBrownfieldImport {
  id           String                 @id @default(uuid())
  projectId    String
  sourceType   String
  sourceName   String?
  status       BrownfieldImportStatus @default(IMPORTED)
  importedAt   DateTime               @default(now())
  notes        String?
  project      Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  networks     DesignBrownfieldNetwork[]

  @@index([projectId])
}

model DesignBrownfieldNetwork {
  id               String               @id @default(uuid())
  projectId         String
  importId          String?
  routeDomainKey    String?
  addressFamily     AddressFamily
  cidr              String
  vlanNumber        Int?
  siteName          String?
  ownerLabel        String?
  sourceObjectKind  BrownfieldObjectKind @default(NETWORK)
  sourceObjectId    String?
  confidence        String               @default("imported")
  notes             String?
  createdAt         DateTime             @default(now())
  project           Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  import            DesignBrownfieldImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([importId])
  @@index([routeDomainKey])
}

model DesignBrownfieldConflictResolution {
  id                 String   @id @default(uuid())
  projectId          String
  conflictKey        String
  code               String
  routeDomainKey     String?
  addressFamily      AddressFamily
  importedCidr       String
  proposedCidr       String?
  existingObjectType String
  existingObjectId   String?
  decision           String
  reviewerLabel      String?
  reason             String
  designInputHash    String?
  supersededAllocationId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, conflictKey])
  @@index([projectId])
  @@index([decision])
  @@index([designInputHash])
}

model DesignAllocationApproval {
  id             String                     @id @default(uuid())
  projectId      String
  allocationId   String
  decision       AllocationApprovalDecision
  reviewerLabel  String?
  reason         String?
  designInputHash String?
  createdAt      DateTime                   @default(now())
  project        Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allocation     DesignIpAllocation         @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([allocationId])
  @@index([designInputHash])
}

model DesignAllocationLedgerEntry {
  id              String                 @id @default(uuid())
  projectId       String
  allocationId    String?
  action          AllocationLedgerAction
  actorLabel      String?
  summary         String
  designInputHash String?
  createdAt       DateTime               @default(now())
  project         Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allocation      DesignIpAllocation?    @relation(fields: [allocationId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([allocationId])
}
