PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/subnetops?schema=public"
CORS_ORIGIN=http://localhost:4173,http://localhost:5173,http://localhost:3000,https://subnetops-frontend.onrender.com
JWT_SECRET="change-this-in-production"
NODE_ENV="development"

SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@subnetops.local"
SEND_REAL_EMAILS=false

AUTOMATION_SWEEP_ENABLED=false
AUTOMATION_SWEEP_INTERVAL_MS=300000
PRISMA_SYNC_ON_BOOT=true
PRISMA_SYNC_STRATEGY=push
DB_PUSH_ON_BOOT=false
SEED_DEMO_ON_BOOT=false

AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
