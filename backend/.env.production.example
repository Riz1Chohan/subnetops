PORT=4000
DATABASE_URL=postgresql://postgres:postgres@db:5432/subnetops?schema=public
CORS_ORIGIN=http://localhost
JWT_SECRET=replace-with-a-long-random-secret
NODE_ENV=production
SEND_REAL_EMAILS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
AUTOMATION_SWEEP_ENABLED=true
AUTOMATION_SWEEP_INTERVAL_MS=300000
PRISMA_SYNC_ON_BOOT=true
PRISMA_SYNC_STRATEGY=push
DB_PUSH_ON_BOOT=false
SEED_DEMO_ON_BOOT=false

AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
